# LLM provider configuration. The defaults work with ZERO configuration:
# everything (make test, make run, make tick) runs against the deterministic
# mock client — no API key, no network.
LLM_PROVIDER=mock

# Option A — any OpenAI-compatible API (LLM_PROVIDER=openai_compatible):
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Option B — Claude directly via the native Anthropic Messages API
# (LLM_PROVIDER=anthropic), no SDK required:
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=4096
